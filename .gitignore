# =============================================================================
# Commit everything under ~/.claude/skills EXCEPT secrets and generated junk.
# (Switched from the earlier opt-in whitelist — all skills are now tracked.)
# =============================================================================

# --- Secrets — NEVER commit ---------------------------------------------------
# .env holds Tavily/Exa keys + X auth_token. .env.* covers .env.local etc.
# .env.example is the committed template (re-included below).
.env
.env.*
!.env.example

# Local, machine-specific Claude permission allowlists — not shared.
**/settings.local.json

# --- Generated / runtime junk -------------------------------------------------
# Runtime caches (docs cache, browser profiles, etc.)
**/.cache/

# Python
__pycache__/
*.pyc

# Node
node_modules/

# Generated per-run artifacts
results.html

# macOS
.DS_Store
