# ~/.claude/skills/.env.example — template for the shared skills key file
#
# SETUP: copy this file to `.env` in the same directory, then fill in keys:
#     cp ~/.claude/skills/.env.example ~/.claude/skills/.env
#     chmod 600 ~/.claude/skills/.env
# Add `.env` to .gitignore so secrets are never committed. Commit THIS file.
#
# Loaded by scripts that use scripts/_env.py.
# Resolution order (first hit wins): real env var → ~/.claude/.env → ~/.claude/skills/.env
# Empty values (KEY=) are skipped. Format: KEY=value (no quotes, no spaces around =).
#
# This .example file is documentation only — it is NEVER loaded. Never put real
# secrets here. As more skills need keys, add them below with a "Used by:" note.
# ===========================================================================

# --- Web search (Tavily → Exa → DuckDuckGo precedence) ---------------------
# TAVILY_API_KEY
#   Used by: scan-trends (web source — primary provider), deep-research (search.py — primary)
#   Get a key (free 1,000 credits/mo): https://app.tavily.com
TAVILY_API_KEY=

# EXA_API_KEY
#   Used by: scan-trends (web source — fallback provider), deep-research (search.py — fallback)
#   Get a key (free 1,000 requests/mo): https://dashboard.exa.ai
EXA_API_KEY=

# --- X/Twitter cookie auth (reuse your already-logged-in session) ----------
# X_AUTH_TOKEN / X_CT0
#   Used by: scan-trends (x.py — authenticated X scrape, no login flow to block)
#   Get them: log into x.com in any browser → DevTools → Application/Storage →
#   Cookies → x.com → copy the VALUE of `auth_token` and `ct0`.
#   NOTE: auth_token ≈ full account access. Keep this file chmod 600.
#   Re-paste if they expire (logout / forced re-auth). Empty = use web fallback.
X_AUTH_TOKEN=
X_CT0=

# --- Google Gemini (YouTube "watch" tier) ----------------------------------
# GOOGLE_API_KEY  (or GEMINI_API_KEY — either name works)
#   Used by: ingest-source (gemini_watch.py — has Gemini watch a YouTube video,
#   audio + visuals, for timestamped notes). OPTIONAL: without it, ingest-source
#   degrades to keyless caption transcripts. Public videos only; YouTube
#   ingestion is currently a free Gemini preview.
#   Get a key (free tier): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# GEMINI_MODEL  (optional override; default gemini-2.5-flash)
GEMINI_MODEL=
